                    "video_name": "georgiatech_bike_06_6"
                },
                {
                    "video_time": 37.891966,
                    "list": "['mechanic is using a good technique of using their leg to provide upward pressure on the wheel', 'allows them to use both hands to secure the axle in place once happy with how it is seated']",
