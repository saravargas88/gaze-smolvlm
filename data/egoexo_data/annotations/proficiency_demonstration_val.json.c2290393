            "tips_for_improvement": [
                {
                    "video_time": 11.668116,
                    "list": "['go into his shooting motion on the right side of the frame']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 15.273008,
                    "list": "['I would love to see his body positioning a little bit lower with knees bent, hips dropped, maybe leaning in with his hands ready to catch and shoot.', 'In a game situation, you have to be ready to catch and shoot, and in this particular frame, his body is kind of straight up.']",
                    "expert_uid": "2g7km5",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 16.705192,
                    "list": "['Bring the ball placement position a little bit higher towards his chest area', 'Improve on a faster release of his jump shot', 'Prevent defenders from being able to block or have a difficult contest on the jump shot', 'Get the ball higher above the shoulder to create more arc, accuracy, and rotation', 'Get the ball at the proper angle to come down through the net above the rim for a completed jump shot']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 16.928708,
                    "list": "[\"He's standing still taking two steps versus ball in the air, feeding the air, walking into his jump shot.\", 'So just being able to walk into your jump shot as the ball is being passed to you versus catching it, then walking it, which is, you know, a traveling violation.']",
                    "expert_uid": "ec8x25",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 17.722521,
                    "list": "['the guide hand to the left, palm is facing outward, five fingers are facing towards the left, giving the ball little or no effect towards the release']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 22.751807,
                    "list": "['more elevation on this jump shot', 'maybe stepping back, bending the knees, and pulling into this pass a little bit more to get power from the hips to lift your body up']",
                    "expert_uid": "2g7km5",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 24.121767,
                    "list": "['You do not want to fall back after you touch the ground with your jump shot.', 'As you jump, you want to kind of land in the same spot versus fade back.', \"That's going to take away from your shot.\", 'Just being able to elevate, come up, come down, pretty much land where you jump from.']",
                    "expert_uid": "ec8x25",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 26.58676,
                    "list": "[\"We'd love to see him in a more ready basketball position.\"]",
                    "expert_uid": "2g7km5",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 29.336268,
                    "list": "[\"The player's momentum is bringing him backwards, which affects the arc of the ball\", 'The ball needs to be able to drop in the proper angle for better accuracy', 'The player should shift the angle of the ball to ensure it drops on the rim']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 33.105291,
                    "list": "['A slight adjustment we will want to make to prevent defenses from having easy access of taking or stealing the ball.', \"Bringing the ball placement position a little bit closer towards the body to be able to have more space from the defender's hands of stripping or swiping at the ball.\"]",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 33.105291,
                    "list": "['This will help improve a quicker release', 'to generate getting the follow-through extension above the shoulder', 'help propel the ball to gain more arc', 'accuracy it needs to get above the rim', 'have the proper angle of dropping through the net']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 33.666546,
                    "list": "['the jump shot needs to come down through the proper angle', 'hitting our targeted area, the middle of the rim']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 38.840448,
                    "list": "['shooting hand should be straight, not crossing the body']",
                    "expert_uid": "2g7km5",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 43.906923,
                    "list": "['That right hand might be a little bit to the right on the ball. You might want to have it a little bit more behind the ball.']",
                    "expert_uid": "2g7km5",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 44.449371,
                    "list": "['We want to move the follow through Hand to come down through the middle of our targeted area']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 50.455627,
                    "list": "['Players should focus on keeping their follow through hand on the same side as the rim to direct the ball in the desired direction.', 'Players should work on generating more lift and arc by maintaining proper momentum and not moving backwards during the shot.']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 50.59025,
                    "list": "['On this particular shot, you want that follow through to be a little bit higher.', 'Remember, you want to keep one longer one short.', 'So the mechanics are there just want to keep that follow through a little bit to make sure that arc is consistent.']",
                    "expert_uid": "ec8x25",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 60.739817,
                    "list": "[\"There's no flexion in his knees.\", 'You want to be able to get more flexion in your knees to be able to balance out the jump shot using your arms and using your knees at the same time.']",
                    "expert_uid": "ec8x25",
                    "video_name": "unc_basketball_03-30-23_02_7"
                },
                {
                    "video_time": 61.27074,
                    "list": "['He could get more lift if he got more legs by stepping into this pass.']",
                    "expert_uid": "2g7km5",
                    "video_name": "unc_basketball_03-30-23_02_7"
                }
            ]
