            "tips_for_improvement": [
                {
                    "video_time": 27.079037,
                    "list": "['struggling to stay connected to the movement', \"movements don't quite make sense\", 'could use some clarity in his movements', 'lose some stiffness in his spine']",
                    "expert_uid": "mg5x5a",
                    "video_name": "upenn_0706_Dance_4_3"
                },
                {
                    "video_time": 37.931164,
                    "list": "['he starts off the beat a bit', 'the steps are very clear as far as the timing', 'on the four and the eight count, that is when your hip kind of pushes to the side', 'to keep the rhythm, you always want to keep that one, two, three accent, one, two, three accent', 'On the four and the eight, you get a little oomph']",
                    "expert_uid": "a44vde",
                    "video_name": "upenn_0706_Dance_4_3"
                },
                {
                    "video_time": 39.371801,
                    "list": "[\"He's really losing track of the technique and of the rhythm of the music.\", 'His head is really loosely kind of hanging on top of his spine here and is really disconnected from the movement of his body as well as the rhythm of the music.', \"His arms could benefit from some more clarity in their shaping, they're just kind of hanging off the sides of his shoulders.\", 'His feet could benefit from some clarity in the movement as well, but also a deeper bend in the knees bringing him more grounded to the floor and more in control of his movement.']",
                    "expert_uid": "mg5x5a",
                    "video_name": "upenn_0706_Dance_4_3"
                },
                {
                    "video_time": 53.34478,
                    "list": "['I would suggest maybe using both arms to move', 'being up on his toes and then pushing those hips side to side on the four and the eight count']",
                    "expert_uid": "a44vde",
                    "video_name": "upenn_0706_Dance_4_3"
                },
                {
                    "video_time": 60.451882,
                    "list": "['His movements feel really disjointed and repetitive.', \"He's got quite a lot of stiffness in his spine, in his shoulders, and up through his neck and head, which is creating an awkwardness in his movements.\", 'Keeping him from connecting to the rhythm and also demonstrating technical skill.']",
                    "expert_uid": "mg5x5a",
                    "video_name": "upenn_0706_Dance_4_3"
                },
                {
                    "video_time": 82.343177,
                    "list": "[\"his movements are too loose and don't really have any specific dynamic qualities to them\", 'finding it hard to embody the rhythm']",
                    "expert_uid": "mg5x5a",
                    "video_name": "upenn_0706_Dance_4_3"
                },
                {
                    "video_time": 84.385194,
                    "list": "['add some sort of variety, even moving a little bit more throughout the space', 'adding both arms a little bit more', 'adding the energy up a bit higher because the movements are still looking the same']",
                    "expert_uid": "a44vde",
                    "video_name": "upenn_0706_Dance_4_3"
                },
                {
                    "video_time": 99.01799,
                    "list": "[\"He took an extra step and now he's off the music again.\", \"Just making sure you're not taking any extra steps.\", \"You have a very clear number of steps that you take and you want to make sure you just take those steps so you don't get off the music.\"]",
