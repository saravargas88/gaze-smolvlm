                {
                    "video_time": 34.827917,
                    "list": "['looking for a new right foot', 'stay opposite opposed having left hand on right foot on in order to really drive and stay balanced']",
                    "expert_uid": "kz25yw",
                    "video_name": "uniandes_bouldering_012_21"
                },
                {
                    "video_time": 37.055732,
                    "list": "['he loses his left foot and starts to drop away from the wall', 'he could have done a better foot placement or pre-tensioned his leg to make the move']",
