                    "expert_uid": "7ygad1",
                    "video_name": "georgiatech_bike_06_6"
                },
                {
                    "video_time": 73.036131,
                    "list": "['I would recommend to cycle through the gears itself before going ahead and finishing the job.', 'And also now the mechanic is making sure that the brake here is sitting properly and the brake pads are now rubbing on the rim itself.']",
                    "expert_uid": "zchsw0",
                    "video_name": "georgiatech_bike_06_6"
                },
                {
                    "video_time": 73.297059,
                    "list": "['remove the wheel in the open position']",
