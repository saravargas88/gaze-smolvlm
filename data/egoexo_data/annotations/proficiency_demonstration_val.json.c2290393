                "exo4": "takes/upenn_0724_Guitar_1_5/frame_aligned_videos/gp04.mp4"
            },
            "good_executions": [
                {
                    "video_time": 37.487796,
                    "list": "['The guitarist is also using a pick to help strum the strings.']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_5"
                },
                {
                    "video_time": 54.903587,
                    "list": "['plays a series of chords with really nice shifting between and nice shapes', 'sounds very pleasant to the ear']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_5"
                },
                {
                    "video_time": 60.842196,
                    "list": "['nice balanced hand shape with finger independence', 'thumb is in the middle of the back of the hand', 'middle two fingers are able to stay relaxed, curved, and right where they would naturally be in the hand', 'alternating frets with his first finger while holding this hand shape', 'textbook example of how your left hand should work on the guitar']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_5"
                },
                {
                    "video_time": 60.908784,
                    "list": "[\"They're doing a really nice job also of keeping a nice anchor in these other fingers.\"]",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_5"
                },
                {
                    "video_time": 141.339386,
                    "list": "['they have this really nice flow', \"there's a lot of weight into the string\", \"they're also anticipating the next notes\"]",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_5"
                },
                {
                    "video_time": 210.498993,
                    "list": "['The guitarist...doing a really nice job', \"they're...anticipating where they're going\", \"there's always this subtle movement of going to the next note\"]",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_5"
                }
            ],
            "tips_for_improvement": [
                {
                    "video_time": 27.788447,
                    "list": "['The guitarist should try plucking the strings instead of drumming them to achieve better note clarity.']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_5"
                },
                {
                    "video_time": 171.616282,
                    "list": "[\"Ideally we're going to want to change to a fingering where we can keep our hand in more of a rounded, less tense shape.\", 'Or if we do do this fingering, we want to shift to that and then maybe use a fingering where we can go from that shift to somewhere logical.', \"We can hear a little bit of muting when the guitarist is doing this underneath his fourth finger because he has to stretch out so much he's not going to be able to put a natural weight into the fret.\", 'So ideally we would want this to either be a changed fingering or a shift so that he can keep the good hand shape, keep his mobility, and keep a good clarity of tone.']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_5"
                },
                {
                    "video_time": 207.060401,
                    "list": "['The guitarist plucked the string too hard', 'We have to make sure that ideally we control our plucking', \"If we are plucking hard, we're always going straight down with our stroke\", 'Never pluck up to avoid string buzz against the fingerboard']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_5"
                }
            ]
        },
