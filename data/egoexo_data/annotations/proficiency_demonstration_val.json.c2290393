                },
                {
                    "video_time": 137.350033,
                    "list": "['Always accentuating the first step, the kick', 'Maintaining shorter second and third movements', 'Repeating the step exactly the same way each time', 'Putting more strain and more stress on the first kick']",
                    "expert_uid": "pc14sf",
