                    "video_name": "unc_basketball_03-30-23_02_15"
                },
                {
                    "video_time": 49.700343,
                    "list": "['The player gave the ball the right amount of spin to be able to hover around our targeted area, which is the top right corner on the box of the backboard.']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_15"
                },
                {
                    "video_time": 55.366851,
