                    "expert_uid": "tja8o9",
                    "video_name": "indiana_music_03_3"
                },
                {
                    "video_time": 38.353405,
                    "list": "['The pianist has a really nice balance between their left hand and their right hand.', 'Both lines can be heard very clearly.']",
