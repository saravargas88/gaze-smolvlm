            "tips_for_improvement": [
                {
                    "video_time": 23.266372,
                    "list": "['He would overall benefit from some refinement and some clarity in the use of the upper body.', \"He's also maintaining quite a lot of disconnection from the rhythm.\", \"He's taking very large steps, which is overall making his movements appear slow and quite jumbled in relation to the rhythm.\"]",
                    "expert_uid": "mg5x5a",
                    "video_name": "upenn_0706_Dance_4_5"
                },
                {
                    "video_time": 38.968386,
                    "list": "['He needs to get back on the correct beat just for Bachata']",
                    "expert_uid": "a44vde",
                    "video_name": "upenn_0706_Dance_4_5"
                },
                {
                    "video_time": 44.102553,
                    "list": "['He could use some refinement in the shape of both his arm as well as his hand.', 'He would also benefit from some rhythmic clarity.', 'He seems to be holding the arm above his head and moving it down to alternate arms without any sort of real rhythmic embodiment or connection to the music.', \"His shoulders are appearing quite stiff as he's doing this movement, which is minimizing his upper body's ability and his spine's ability to connect to the rhythm and connect to the lower body in general.\"]",
                    "expert_uid": "mg5x5a",
                    "video_name": "upenn_0706_Dance_4_5"
                },
                {
                    "video_time": 56.061233,
                    "list": "['Takes a few extra steps before getting back on the correct beat']",
                    "expert_uid": "a44vde",
                    "video_name": "upenn_0706_Dance_4_5"
                },
                {
                    "video_time": 72.053799,
                    "list": "[\"He's got this pelvis really jutted out to the side and this knee turned in on the same leg, which is creating this contradictory flow of movement in his lower body\", \"If you were to minimize the movement of the pelvis, you'd be able to move the lower body more quickly and efficiently, and also be able to find some more clarity in the upper body.\"]",
                    "expert_uid": "mg5x5a",
                    "video_name": "upenn_0706_Dance_4_5"
                },
                {
                    "video_time": 85.083637,
                    "list": "['Disconnecting his feet from one another', 'Significant turnout in both feet', 'Significant bend in both of his knees', 'Lack of clarity in his arms and his upper body', 'Upper body twisting off of his pelvis', 'Head floating above the upper body', 'Disconnected from the rhythm of the music']",
                    "expert_uid": "mg5x5a",
                    "video_name": "upenn_0706_Dance_4_5"
                },
                {
                    "video_time": 87.775679,
                    "list": "[\"He took an extra step when he didn't need to\", \"He's off the timing of the music again\"]",
                    "expert_uid": "a44vde",
