                {
                    "video_time": 75.793294,
                    "list": "['The pianist has demonstrated a very clear trill in the right hand.', \"Because they're using their fingertips, they have more control in their hand to make sure it's very even.\"]",
                    "expert_uid": "tja8o9",
                    "video_name": "indiana_music_03_3"
                },
                {
                    "video_time": 82.252093,
                    "list": "['the pianist is doing a really nice job of using the left hand to bring out the harmonies and make it sound more interesting.']",
                    "expert_uid": "tja8o9",
                    "video_name": "indiana_music_03_3"
                },
                {
                    "video_time": 90.95003,
                    "list": "['the pianist is playing really healthily with their left hand', 'making the voicing of the harmony sound so much more interesting']",
