                    "video_name": "uniandes_dance_002_3"
                },
                {
                    "video_time": 48.746496,
                    "list": "['I think he might have went on the wrong foot to go back the other direction.', \"When he steps forward, step right back on his left foot so that way it's already stepping back and he can easily spin around.\", \"He took kind of an extra step so he ended up stepping with the other leg so it just wasn't as smooth as it could have been.\"]",
                    "expert_uid": "a44vde",
