                    "video_name": "unc_basketball_03-30-23_02_6"
                },
                {
                    "video_time": 4.584827,
                    "list": "['Definitely could use more lift on this layup for more game-like feel.']",
                    "expert_uid": "500w0s",
                    "video_name": "unc_basketball_03-30-23_02_6"
                },
                {
