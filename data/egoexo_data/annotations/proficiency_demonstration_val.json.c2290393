            "good_executions": [
                {
                    "video_time": 7.725786,
                    "list": "['properly aligning the axle into the dropouts', 'using the shifter to shift the derailleur to the outermost or innermost gear to make aligning the chain and getting the wheel into the dropouts easier']",
                    "expert_uid": "7ygad1",
                    "video_name": "georgiatech_bike_06_6"
                },
                {
                    "video_time": 10.055681,
                    "list": "['Pulling the derailleur down will relieve some of the tension']",
