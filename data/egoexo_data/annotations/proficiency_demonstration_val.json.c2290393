                    "video_name": "uniandes_bouldering_012_21"
                },
                {
                    "video_time": 64.804582,
                    "list": "['utilizing this kind of twist', 'thumb is still engaged and pinching really nicely', 'coordinates movements', 'maintain tension through his whole body']",
