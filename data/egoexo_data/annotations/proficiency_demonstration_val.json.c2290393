            "task_id": 5003,
            "task_name": "Playing Guitar - Suzuki Books",
            "scenario_name": "Music",
            "university_id": "ego4d-penn",
            "origin_participant_id": "61",
            "take_uid": "411408c0-8f5f-4698-a9c5-5e491ecba021",
            "video_paths": {
                "ego": "takes/upenn_0724_Guitar_1_3/frame_aligned_videos/aria01_214-1.mp4",
                "exo1": "takes/upenn_0724_Guitar_1_3/frame_aligned_videos/gp01.mp4",
                "exo2": "takes/upenn_0724_Guitar_1_3/frame_aligned_videos/gp02.mp4",
                "exo3": "takes/upenn_0724_Guitar_1_3/frame_aligned_videos/gp03.mp4",
                "exo4": "takes/upenn_0724_Guitar_1_3/frame_aligned_videos/gp04.mp4"
            },
            "good_executions": [
                {
                    "video_time": 29.250235,
                    "list": "['This is a good example of balance between the bass notes and the upper chordal tones. This is what we want to hear when a guitarist plays chords. The bass note is not overpowering the upper notes of the chord.']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 33.630985,
                    "list": "['The guitarist is strumming two strings while using their thumb and their first finger.']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 34.293964,
                    "list": "['This is a good example of electric guitar technique.', 'The palm of the hand through the thumb in the left hand is very relaxed.']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 44.511457,
                    "list": "['The guitarist did a nice job of bringing out the movement in the bass notes']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 96.361819,
                    "list": "['playing in the most ergonomic position', 'having both their feet flat on the floor']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 116.565076,
                    "list": "['good left hand technique', 'gentle curve in the left hand fingers', 'playing with fingertips']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 159.770956,
                    "list": "['all three fingers have the same volume']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                }
            ],
            "tips_for_improvement": [
                {
                    "video_time": 36.49449,
                    "list": "['Just note that they just played the hit more with the nail of their thumb, resulting in more of a metallicy sound.', 'They should try just to practice repetitions where they just get the thumb, the pad of the thumb, to get a better sound.']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 44.511457,
                    "list": "[\"It's always important to bring out any moving note.\"]",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 49.083842,
                    "list": "['The thumb and fingers IMAD are slightly out of sync rhythmically. The solution of this would be to really think of fingers 2, 3, 4 or IMAD as a unit and move them as such, instead of letting each finger move slightly independently in the right hand.']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 53.278852,
                    "list": "[\"The guitarist's guitar is not properly in tune.\", 'Some of the strings are slightly flat.']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 55.594466,
                    "list": "['They just need to make sure that they hit the pad of the finger to get a better sound.']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 58.880479,
                    "list": "['They should try using the flesh of their fingertips rather than their nails to produce a warmer sound.']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 67.64696,
                    "list": "['Note where they hit the nail with their thumb.']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 69.392188,
                    "list": "['The pluck of the string has slightly too much outwards motion', 'The ideal thing would be to have all of the motion of the pluck be straight down toward the floor']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 77.326074,
                    "list": "['The guitarist with finger number four in the right hand or finger A in the right hand is not getting enough of his nail onto the string to pull a clean tone. Try to get more of the nail onto the string to avoid the twangy sound.']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 80.906104,
                    "list": "[\"The guitarist is plucking the lower strings too hard, which is causing them to buzz. Especially when plugged into an amp, we need to rely on the sound of the amp to create our volume and pluck lighter on these low strings so that they don't buzz.\"]",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 88.750898,
                    "list": "['They could use a little bit more weight in their fingers to get more of a sound coming out.']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 96.361819,
                    "list": "['instead of having their foot on its side']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 104.718827,
                    "list": "['We are hearing a slight pause in the tempo as a guitarist descends these arpeggios. Ideally the tempo would be consistent. The recommended course of action would be to play these slightly slower so that the guitarist is able to get to that next note of the arpeggio without having a break in the rhythm.']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 106.970278,
                    "list": "[\"The guitarist should trim their nails so they don't get in the way.\"]",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 138.040436,
                    "list": "['the guitarist is playing very lightly on the guitar. I think they could have a little bit more substance with the pads of their fingers to get a healthier sound']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 151.279213,
                    "list": "['We need to make sure that all three of these notes have equal volume.']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 159.770956,
                    "list": "['thinking of those three fingers as one strumming motion']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 189.06797,
                    "list": "[\"When you're hearing different notes of this arpeggio come out louder than other notes, ideally every single note of the arpeggio would be as present and as loud as any other note.\"]",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 202.641822,
                    "list": "['The top note of the arpeggio is muted.', 'The first finger is touching the string that needs to vibrate.', 'Each finger should only touch the string it is holding down.', \"Make sure each finger is curved enough so that it doesn't touch any other string.\"]",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 209.460284,
                    "list": "['They can use more of their fingers pulling the string to get a bigger sound.']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0724_Guitar_1_3"
                },
                {
                    "video_time": 221.971524,
                    "list": "['The guitarist should focus on playing with stable rhythm.']",
                    "expert_uid": "vsudlg",
                    "video_name": "upenn_0724_Guitar_1_3"
                }
            ]
        },
