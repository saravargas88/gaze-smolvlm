            "tips_for_improvement": [
                {
                    "video_time": 5.318283,
                    "list": "['We would like to have his right hand over more to the middle section of the ball.', 'Take his right index finger and replace it more towards the middle of the ball.', 'Slide his entire hand over to the left placing it more in the middle of the ball.', 'Slide his left hand more to the side of the ball so that his hand is not in the path of the ball.']",
