            "tips_for_improvement": [
                {
                    "video_time": 4.282699,
                    "list": "['To become more efficient is to incorporate the correct footwork by stepping initially with her left foot first and having her right foot come down second going into her jump shot.', 'Or the player can jump on two feet allowing a wider base, a more balanced base, to allow the player to become more fluent going into her release.']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_02-24-23_01_19"
                },
                {
                    "video_time": 4.308811,
                    "list": "['Her feet are really, really close together. Ideally, you want your feet to be one foot in front of the other.', \"If you're a right-hand shooter, the right foot should be slightly in front.\", 'Her knees are kind of locked out.', \"It looks like she's kind of got two hands on the ball.\"]",
                    "expert_uid": "2g7km5",
                    "video_name": "unc_basketball_02-24-23_01_19"
                },
                {
                    "video_time": 4.445,
                    "list": "[\"It's to not have both her hands push the ball outwards towards the rim\", 'establishing a shooting hand, preferably her right hand, getting it underneath the ball', 'allowing more ball control and alignment on the release']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_02-24-23_01_19"
                },
                {
                    "video_time": 4.445,
                    "list": "['Have her right hand extended higher above her shoulder on the release', 'Allow her five fingers and wrist to snap downward towards the rim', 'Allow the ball to gain more arc accuracy and rotation', 'Give the ball the proper and accurate angle of dropping inside the rim']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_02-24-23_01_19"
                },
                {
                    "video_time": 4.584459,
                    "list": "[\"She's shooting with two hands which throws off the accuracy of the shot.\", 'Both wrists are breaking, which affects the accuracy and backspin rotation.', 'She takes a big step with her left foot, causing her to be off balance.', 'She should designate a shooting hand and work on the shooting mechanics.', \"Moving in close or tighter can help offset shooting mechanics that aren't in line.\"]",
                    "expert_uid": "2g7km5",
                    "video_name": "unc_basketball_02-24-23_01_19"
                },
                {
                    "video_time": 7.788318,
                    "list": "['getting her guide hand more on the side of the ball', 'having a flat hand facing the opposite way', 'allowing the guide hand to be used as just a placeholder', 'having no effect on the release']",
