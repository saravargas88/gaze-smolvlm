                    "video_name": "uniandes_dance_019_58"
                },
                {
                    "video_time": 38.35168,
                    "list": "['bend their knees', 'exert less energy']",
                    "expert_uid": "r2u6t3",
                    "video_name": "uniandes_dance_019_58"
                },
                {
                    "video_time": 39.41892,
                    "list": "[\"She's performing the movement quite small and not 100% full out.\", 'She appears quite unsure here.', 'Her gaze is really looking off to the side, disconnected from the rest of her body.']",
                    "expert_uid": "mg5x5a",
                    "video_name": "uniandes_dance_019_58"
                },
                {
                    "video_time": 43.335863,
                    "list": "['She should work on memorization to improve her performance', 'Her technical skill and connection to the rhythm decreases when she appears to be confused']",
                    "expert_uid": "mg5x5a",
                    "video_name": "uniandes_dance_019_58"
                },
                {
                    "video_time": 44.02516,
                    "list": "[\"I would encourage them to be very sharp on what they're doing and over anticipate their movements\"]",
                    "expert_uid": "r2u6t3",
                    "video_name": "uniandes_dance_019_58"
                },
                {
                    "video_time": 51.648478,
                    "list": "['encourage them to take bigger steps', 'plie or bend their legs even further', 'their scoop almost touches the ground', 'digging into getting closer to the ground']",
                    "expert_uid": "r2u6t3",
                    "video_name": "uniandes_dance_019_58"
                },
                {
                    "video_time": 54.054711,
                    "list": "[\"She's bouncing too much in her upper body, which is not connected to the rhythm\", 'Her head is also moving quite significantly, which is throwing her off the rhythm', 'Overall making this movement appear awkward and out of place']",
                    "expert_uid": "mg5x5a",
                    "video_name": "uniandes_dance_019_58"
                },
                {
                    "video_time": 57.31572,
                    "list": "['continue to pay close attention from their wrists all the way to their fingertips', 'make sure that that has as much energy as their arms do', 'looks like a great attention to detail']",
                    "expert_uid": "r2u6t3",
                    "video_name": "uniandes_dance_019_58"
                },
                {
                    "video_time": 65.689063,
                    "list": "['be very clear on when they should be on the balls of their feet versus when they should be flat-footed', 'being clear on whether the articulation of the feet would take it to the next level']",
                    "expert_uid": "r2u6t3",
                    "video_name": "uniandes_dance_019_58"
