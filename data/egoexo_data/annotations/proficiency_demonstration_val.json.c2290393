                    "video_name": "uniandes_bouldering_012_21"
                },
                {
                    "video_time": 60.932785,
                    "list": "['he did decide to bring up a higher left foot', 'he allows himself to really sit down on both of his legs', 'it allows him to really put as much weight on his legs as much as possible', 'we can see those straight arms, even on the same handholder here']",
                    "expert_uid": "2z4v0b",
                    "video_name": "uniandes_bouldering_012_21"
                },
