            "tips_for_improvement": [
                {
                    "video_time": 39.246165,
                    "list": "[\"The pianist is playing with flat fingers which isn't the best for their coordination.\", \"They'll get more clarity if they were to bring their hand a little bit further up and play with their fingertips.\"]",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0721_Piano_1_4"
                },
                {
                    "video_time": 54.459656,
                    "list": "[\"The hand is coming up really far off the keyboard. If they wanted to have more coordination, they would keep their hand as close to the keyboard as possible, especially when playing fast. They'll have more control and it will come across clear.\"]",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0721_Piano_1_4"
                },
                {
                    "video_time": 63.471317,
                    "list": "['they could try to play at a slower tempo', 'they can try to use more rotation from their wrist to help the fingers get quicker into the key']",
                    "expert_uid": "tja8o9",
                    "video_name": "upenn_0721_Piano_1_4"
                },
                {
