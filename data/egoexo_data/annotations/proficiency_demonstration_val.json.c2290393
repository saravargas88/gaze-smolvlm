                {
                    "video_time": 60.149072,
                    "list": "[\"his body's kind of staying a little bit more square\", 'his knees facing out instead of twisting in', 'square style is going to really let him toe in and keep his hips powerful', \"keep tension with this right foot that's down to the right\", 'allow him to kind of cross up and over and get this top of the pinch']",
                    "expert_uid": "kz25yw",
                    "video_name": "uniandes_bouldering_012_21"
                },
                {
                    "video_time": 60.476,
                    "list": "['the climber is able to get their right foot up', 'flag this left foot down as a counterbalance', 'surf this left hand up onto the top of this tufa rail here']",
