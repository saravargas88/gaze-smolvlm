                {
                    "video_time": 15.166907,
                    "list": "['The participant should work on their first touch to cover a slightly bigger distance.', 'They should improve their balance when reaching for a pass.', 'They need to generate more power when hitting the ball.']",
                    "expert_uid": "3u75lz",
