                },
                {
                    "video_time": 52.754453,
                    "list": "['He could twist his right knee in and drive his hips straight to the wall.', 'He could drive his knee straight out to the right to bring his hips closer to the wall.', 'He can bring his left foot up to actively smear and keep tension against the wall.']",
                    "expert_uid": "kz25yw",
