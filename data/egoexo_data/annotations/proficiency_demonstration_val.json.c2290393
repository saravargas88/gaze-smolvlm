                },
                {
                    "video_time": 4.103513,
                    "list": "['A slight improvement we can make as the player is going into his right-handed reverse layup attempt on the right frame is to bring his ball placement position higher towards his shoulder area, creating more security and protection on the ball from opposing defenders in a game-like scenario, being in their defensive stance, having easy access of stripping, taking, or stealing the ball.']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_3"
                },
                {
                    "video_time": 4.103513,
                    "list": "['A slight improvement we can make as the player is going into his right-handed reverse layup attempt on the right frame is to bring his ball placement position higher towards his shoulder area, creating more security and protection on the ball from opposing defenders in a game-like scenario, being in their defensive stance, having easy access of stripping, taking, or stealing the ball.']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_3"
                },
                {
