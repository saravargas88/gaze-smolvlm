                {
                    "video_time": 158.123406,
                    "list": "[\"That's not needed and you should not do that.\", 'You should just have your swab enter into one nostril and swab around in a circular motion five times.', \"There's no need to hold one side of your nostril closed while swabbing your nose.\", \"Maybe you wouldn't get a good sample because you're restricting that area there to get a good sample.\", \"You're gonna have to mouth breathe at this point if you don't have that one nostril open as well.\"]",
                    "expert_uid": "peuv6i",
                    "video_name": "georgiatech_covid_06_4"
                },
                {
                    "video_time": 158.123406,
                    "list": "[\"That's not needed and you should not do that.\", 'You should just have your swab enter into one nostril and swab around in a circular motion five times.', \"There's no need to hold one side of your nostril closed while swabbing your nose.\", \"Maybe you wouldn't get a good sample because you're restricting that area there to get a good sample.\", \"You're gonna have to mouth breathe at this point if you don't have that one nostril open as well.\"]",
