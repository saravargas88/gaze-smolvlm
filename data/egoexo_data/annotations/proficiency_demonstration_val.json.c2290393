            "tips_for_improvement": [
                {
                    "video_time": 4.124221,
                    "list": "['We will want the player to get lower in an athletic stance, allowing him more lift going into his jump, helping the ball gain more arc and momentum to get above the rim, giving it an opportunity of dropping inside the rim.']",
                    "expert_uid": "6jm95g",
                    "video_name": "unc_basketball_03-30-23_02_6"
                },
                {
                    "video_time": 4.35799,
                    "list": "[\"from this angle it's hard for you you can't see how high his knee is\", 'when that knee is up we want to get that knee up to his waist level when we jump off of one foot', 'if we jump off our left foot and we get that right knee up to our waist level that really helps us to explode into the air and get up to the highest point possible with our jump']",
                    "expert_uid": "bsgo5b",
                    "video_name": "unc_basketball_03-30-23_02_6"
                },
                {
                    "video_time": 4.524654,
                    "list": "['Ideally, we would want his left arm out and extended to further protect the ball from the defense.', 'Having his off arm up can also help to protect the ball as he releases the reverse layup.']",
