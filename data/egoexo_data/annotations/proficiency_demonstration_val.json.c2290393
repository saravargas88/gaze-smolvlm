                {
                    "video_time": 54.592319,
                    "list": "['Nice big step with the left foot followed by the right.', 'Spacing underneath the feet.', 'Brings left hand guide hand on the ball.', 'Knows where he is on the court.', 'Eyes and head are up on the basket.']",
